{
  "expo": {
    "name": "The Cyber Cruciora",
    "slug": "cyber",
    "version": "2.1.6",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "the-cyber-cruciora",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cyber.cruciora"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#00000000"
      },
      "package": "com.cyber.cruciora",
      "versionCode": 14,
      "targetSdkVersion": 35,
      "permissions": [
        "com.android.vending.BILLING"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "androidGradlePluginVersion": "8.3.2",
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "ndkVersion": "27.1.12297006",
            "extraGradleProperties": {
              "android.bundle.enableUncompressedNativeLibs": "false",
              "org.gradle.jvmargs": "-Xmx4g -XX:MaxMetaspaceSize=1g"
            },
            "packagingOptions": {
              "jniLibs": {
                "useLegacyPackaging": false
              }
            }
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/1767338091772.png",
          "backgroundColor": "#000100"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fada601f-73a5-4dba-af9a-9bc2209bdb9c"
      }
    },
    "owner": "gokul_04"
  }
}